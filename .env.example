# Google OAuth (NextAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Required in production (Vercel). AUTH_SECRET is accepted as an alias.
NEXTAUTH_SECRET=
# AUTH_SECRET=

# Force in-memory storage (matches Vercel/serverless behavior locally)
# PLANASIA_MEMORY_STORE=1

# Gemini AI
GEMINI_API_KEY=
# Optional model overrides
# GEMINI_TEXT_MODEL=gemini-2.0-flash
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# Google Cloud Translation API (Store auto-translate — optional; falls back to Gemini)
GOOGLE_TRANSLATE_API_KEY=

# Stripe (live payments — PromptPay supported for TH)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# IP Geolocation (optional — ipapi.co free tier)
IPAPI_KEY=

# Public site URL for SEO (sitemap, Open Graph, canonical links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (recommended for Vercel — persistent store listings)
# Project ref: tkvloptwmmybyeztpluf
NEXT_PUBLIC_SUPABASE_URL=https://tkvloptwmmybyeztpluf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — optional fallback cloud storage (jobs queue, other JSON blobs)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
